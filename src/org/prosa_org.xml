<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet href="http://moise.sourceforge.net/xml/os.xsl" type="text/xsl" ?>
<organisational-specification
    id="factory_prosa_org"
    os-version="0.8"
    xmlns='http://moise.sourceforge.net/os'
    xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
    xsi:schemaLocation='http://moise.sourceforge.net/os http://moise.sourceforge.net/xml/os.xsd' >

    <structural-specification>
        <!-- PROSA is holonic/heterarchical: flat peer groups for negotiation -->
        <role-definitions>
            <role id="resource_holon"/>
            <role id="order_holon"/>
            <role id="product_holon"/>
            <role id="staff_holon"/>
            <role id="supervisor"/>
            <role id="transport_holon"/>
        </role-definitions>

        <group-specification id="shop_floor">
            <roles>
                <role id="resource_holon" min="1" max="100"/>
                <role id="order_holon" min="0" max="1000"/>
                <role id="product_holon" min="1" max="10"/>
                <role id="supervisor" min="1" max="1"/>
                <role id="transport_holon" min="0" max="100"/>
            </roles>
            <!-- No links/authority between orders and resources. They negotiate as peers -->
        </group-specification>
    </structural-specification>

    <functional-specification>
        <scheme id="production_scheme">
            <goal id="fulfill_order">
                <plan operator="sequence">
                    <goal id="negotiate_resource"/>
                    <goal id="execute_operation"/>
                </plan>
            </goal>
            <mission id="m_order" min="1" max="1000">
                <goal id="fulfill_order"/>
            </mission>
            <mission id="m_resource" min="1" max="100">
                <goal id="execute_operation"/>
            </mission>
        </scheme>
    </functional-specification>

    <normative-specification>
        <norm id="n1" type="obligation" condition="unfulfilled" role="order_holon" mission="m_order"/>
        <norm id="n2" type="obligation" condition="unfulfilled" role="resource_holon" mission="m_resource"/>
    </normative-specification>
</organisational-specification>
